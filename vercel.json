{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "packages/server/dist/public",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "packages/server/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
